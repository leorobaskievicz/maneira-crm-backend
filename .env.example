DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=dev
DB_PASSWORD=your_db_password_here
DB_DATABASE=maneira_crm

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

PORT=3000
UPLOAD_DIR=uploads

# Uploads — AWS S3
# Em dev usa o profile ~/.aws (cadeia padrão de credenciais).
# Em produção (Railway) defina AWS_ACCESS_KEY_ID e AWS_SECRET_ACCESS_KEY.
S3_BUCKET=maneira-crm-uploads-xxxxx
S3_REGION=sa-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
